# Copy to .env and fill in your camera details
USERNAME=admin
PASSWORD=your_password_here

# This machine's LAN IP — used for Docker LAN mode (open player from phone/TV)
HOST_IP=192.168.60.51

# Camera network (discover with discover_rtsp_cameras.py)
RTSP_HOST=192.168.60.41
RTSP_PORT=5543
RTSP_PATH=/live/channel0

# ONVIF (CP Plus cameras often use port 8000)
ONVIF_ENABLED=true
ONVIF_PORT=8000
ONVIF_PROFILE=0
HTTP_PORT=8000

# Optional: full RTSP URL overrides host/port/path
# RTSP_URL=rtsp://admin:pass@192.168.1.100:5543/live/channel0

# Playback
LOW_LATENCY=true
STREAM_FPS=20
SNAPSHOT_PATH=/tmpfs/auto.jpg
